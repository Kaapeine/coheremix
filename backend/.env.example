# PostgreSQL connection string
DB_URL=postgresql://coheremix:coheremix@localhost:5432/coheremix

# Cloudflare R2 (leave unset to use local disk storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PRESIGN_EXPIRES=3600

# Directories (defaults are relative to the backend package; override for Docker/prod)
DATA_DIR=./data
STORAGE_DIR=./data/storage

# Loudness target for gain-matching (LUFS)
TARGET_LUFS=-14.0

# Sample rate used throughout the analysis pipeline (Hz)
ANALYSIS_SAMPLE_RATE=48000

# Maximum upload size per file (bytes); default is 100 MB
MAX_UPLOAD_BYTES=104857600

# Maximum track duration accepted (seconds); default is 15 minutes
MAX_DURATION_S=900

# Hours before uploaded comparisons are swept by the cleanup job
TTL_HOURS=24.0
